{
  "name": "chessbook",
  "description": "Read, study, and explore chess ebooks directly in your browser with lichess.org",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt -b brave",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "format": "prettier --write ./src"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.6",
    "@wxt-dev/module-svelte": "^2.0.4",
    "bits-ui": "^2.14.4",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.48.0",
    "svelte-check": "^4.3.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.6"
  },
  "dependencies": {
    "@lucide/svelte": "^0.562.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tiptap/core": "^3.14.0",
    "@tiptap/extension-bubble-menu": "^3.14.0",
    "@tiptap/pm": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.1",
    "dexie": "^4.2.1",
    "mode-watcher": "^1.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  }
}
